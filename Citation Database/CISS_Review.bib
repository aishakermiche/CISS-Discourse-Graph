@article{liu_chirality-driven_2021,
	title = {Chirality-driven topological electronic structure of {DNA}-like materials},
	volume = {20},
	issn = {1476-1122, 1476-4660},
	url = {https://www.nature.com/articles/s41563-021-00924-5},
	doi = {10.1038/s41563-021-00924-5},
	abstract = {\#\#\# Summary:
{CISS} experimental observations can be accounted for by polarisation of the orbital angular momentum ({OAM}) of the electron within the chiral molecule, instead of unrealistically high levels of {SOC} required by contemporary theoretical models. The chiral molecule acts as an orbital polariser and filter, and it enhances spin polarisation iff there is {SOC} at the lead (pre-entry into the chiral molecule). 

The orbital-polarisation effect ({OPE}) arises necessarily from symmetry analysis. By preservation of time-reversal symmetry, the {OAM} reverses at states with opposite phase parameters (k$_{\textrm{z}}$ and -k$_{\textrm{z}}$). By breaking of inversion symmetry, the band gap between orbital states remains large even when the geometry is disturbed.
Therefore, psuedo-"one way transport channels" are set up, where electrons moving in opposite directions will have opposite orbital polarisations, protected by the band gap.

As the band gap is wide, {OPE} is robust to thermal noise, accounting for the presence of {CISS} at room temperature. {OPE} also accounts for three relevant categories of {CISS} experiments in place of {SOP}.

1. Unidirectional Conductance
{OPE} is present transiently due only to the geometry of the chiral molecule, resulting in preferred transmission directions. Since {OPE} results in spin-polarisation when an {SOC} is introduced pre-entry, {OPE} is a direct contributing factor to {CISS} observations.
Longer molecules also increase spin-polarisation. However, there is a critical length for the molecule at which spin polarisation plateaus.

2. Magnetoresistance
A uni-directional exchange magnetic field is placed on the leads (i.e. magnetic leads), locking the orbital direction of electrons. If this direction contrasts with {OPE} in the chiral molecule, conductance is severely diminished. If they are the same, conductance is enhanced. Dephasing is added by a virtual lead (imaginary self-energy) to enable non-reciprcal {MR}; however, the electrons become incoherent when dephasing is too large.

3. Chemical adsorption
Unidirectional conductance as above affects charge-transfer (redistribution between molecule and subtrate) speeds. Adsorption of chiral molecules by a magnetic substrate does not favour chiralities equally. Charge transfer is the main mechanism for chemical adsorption findings; spin-polarisation and exchange coupling are higher-order effects.


\#\#\# Additional Detail:
- Building Hamiltonian of tight-binding model
Previous simulations do not consider the role of separate electron orbitals when building their tight-binding models, assuming a one-band picture. Liu et al. used the usual two-terminal chiral model (three-fold screw rotation geometry) but with p+, p0, and p- modes on each site, to account for the triplet band structure.

- Dephasing
Dephasing is not necessary for the conductance simulation since the leads are no longer single-mode like usual, but it is necessary for the magnetoresistance simulations to disrupt charge conservation and reciprocity.

- Conductance Calculations
Simulation shows non-linear I-V relations in line with the literature for magnetoresistance experiments but deviates in being asymmetric for different voltage signs. Authors note that resistance relations from simulation correlate with electrical magnetochiral anisotropy (conductor regime with {TRS}- and {IS}-breakage). Authors speculate that {IS} and {TRS} breaking from setups in literature can be distributed any of the parts of the setup (leads and conductor) to achieve {CISS}.

- Transmission vs Transport
The bulk of the paper investigated transport phenomena (i.e. quasi-1D transport), while transmission occurs in free space. Simulations in the main body are irrelevant to this case, and furthermore, {SOC} in the main set-up is negligible in some transmission experiments.
The authors propose the following account:

Taking the substrate/lead {SOC} to be negligible, after scattering by the chiral molecules, the electrons carry a quantised global {OAM} (unbound by atomic potentials). This {OAM} can be measured by first converting to spin-polarisation via {SOC} in/before the detector, then taking {MR} readings.


\#\#\# Further Work / Comments:
- Authors' Suggestion: Measure {OAM} in transmission experiments using vortex electron-beam methods to determine {OAM} contribution.
- Inconsistency: Asymmetry between +/-V in I-V relations are not consistent with experiments (symmetric behaviour).
- Not very topological. Topological classification possible? {TODO}.


\#\#\# Key Takeaways:
{CISS} in transport-experiments requires two components: {SOC} and (chirality-induced-){IS} breaking, which allows the {OPE} of an electron travelling through the chiral molecule to become spin-polarised. {TRS}-breaking not required. Furthermore, {CISS} may be observed even in non-chiral molecules, so long as {IS}-breaking occurs; the {OPE} will depend on the specific symmetry of the material. The orbital degree of freedom makes up for the low contribution of {SOC} and warrants further study.},
	pages = {638--644},
	number = {5},
	journaltitle = {Nature Materials},
	shortjournal = {Nat. Mater.},
	author = {Liu, Yizhou and Xiao, Jiewen and Koo, Jahyun and Yan, Binghai},
	urldate = {2023-01-08},
	date = {2021-05},
	langid = {english},
	file = {Accepted Version:C\:\\Users\\19496\\Zotero\\storage\\3CH6S25Y\\Liu et al. - 2021 - Chirality-driven topological electronic structure .pdf:application/pdf},
}

@article{utsumi_spin_2020,
	title = {Spin selectivity through time-reversal symmetric helical junctions},
	volume = {102},
	issn = {2469-9950, 2469-9969},
	url = {https://link.aps.org/doi/10.1103/PhysRevB.102.035445},
	doi = {10.1103/PhysRevB.102.035445},
	abstract = {\#\#\# Summary:
Explicit calculations and numerical simulations on elastic scattering show that {CISS} still occurs (with max. polarisation {\textasciitilde}90\%) with {TRS}-preservation (no leak currents, Buttiker probes, etc.) in 2-terminal setups iff there are 2-or-more orbitals (4 spin-channels: p$_{\textrm{x}}$ and p$_{\textrm{z}}$; ↑ and ↓ for each) through which the electrons are transferred. As a preliminary step, the authors construct the scattering matrix and show that Bardarson's no-go theorem is not violated under their 2-terminal, 2-channel regime.

- Model Building

In building the (helical-chain model's) Hamiltonian, {SOI} invoked eschews the usual inter-atomic Rashba-{SOI} (electron transfer between π orbitals across sites). Instead, the authors use an intra-atomic {SOI} (electron transfer between π and σ orbitals), which perturbatively gives rise to a strong inter-atomic {SOI}. 

Taking orbital anisotropies to be very large, only p$_{\textrm{x}}$ and p$_{\textrm{z}}$ orbitals partake in transport; the Hamitonian is thus quasi-1D since it has rotational symmetry along the molecular length-wise axis. The intra-atomic {SOI} strength is an independent variable, and its contribution to the Hamiltonian is dependent on the curvature of the helix.
Prominent results from the analysis are listed under Key Takeaways. 

Its band structure is then analysed by deriving the energy spectrum under periodic-boundary conditions. The authors group the spinors into two subsystems: subsystem+ contains x$_{\textrm{↑}}$ and z$_{\textrm{↓}}$; subsystem- contains x$_{\textrm{↓}}$ and z$_{\textrm{↑}}$. Eigenvalues obtained are degenerate pairs, with each pair corresponding to spin states in the same direction, indicating spin-polarisation. Polarisation is strongly energy-dependent.

To account for the above, setting completely decoupled subsystems (i.e. zero torsion in model), with non-zero {SOI}, avoided-crossings occur at the boundaries of the Brillouin zone, ensuring unidirectional spin current at the corresponding energies of the avoided-crossings. (In Fig. 7, note that ↑ and ↓-spin bands have a 2π phase difference, while the Brillouin zone spans from -π to 9π given N = 10. See Fig. 3 for parameter choices.)

- Analytic Derivation

The authors perform a symmetry analysis and conclude that N {\textgreater} 2 is necessary (else Hamiltonian is independent of σ$_{\textrm{x}}$ and becomes invariant when flipping spin/orbit, resulting in no conductance.) Also see point 1 of Key Takeaways. The scattering matrix is explicitly calculated in the wide-band limit (finite self-energy \& very large lead constants), and an explicit expression for spin polarisation is derived.

\#\#\# Comments:
- Conductance assumed to be linear response; current literature on scattering experiments shows inverse I-V relation.
- Alternative {SOI} sources/mechanisms to be further looked up; differences need to be detailed across models.
- Subsystem grouping seems ad-hoc. {TODO}: work out on paper.
- Possibility of topological protection as electrons breach avoided crossings? (See Fig. 5 \& 7.) Quasi-edge state?
- Authors state that unit cell under periodic-boundary conditions must be longer than 2 sites for spin-polarisation. (Curve must not lie on a plane, else curvature will be zero.) Possibility of extending analysis beyond helical geometry (i.e. constant finite curvature \& torsion setup)? {TODO}: {CISS} in achiral molecules; to search. How applicable is Frenet-Serret frame there?
- To note: in numerical model, {SOI} strength is 0.4J {\textasciitilde} 12 {meV} to match {SOI} coupling energy in carbon nanotubes. Under ideal conditions, polarisation {\textasciitilde}0.9. Unit-cell N = 10; Model length = 20.
- Scattering matrix consists of complex quaternions. {TODO}: have no clue what to do with this; {KIV}.
- Calculations mostly concern zero torsion. Is model applicable to actual bio-materials? (Is it too sensitive? Energy window for high-polarisation looks quite narrow {\textasciitilde}20meV.) 
- {TODO}: Compare charge + spin current conductances with those argued by Fransson.


\#\#\# Key Takeaways:
- Polarisation direction is dependent on chirality direction and independent of potential bias direction; it is also opposite in left- and right-leads. Conductance is independent of sgn({SOI}) (unless the applied electric field itself induces Rashba-{SOI}.)
- Polarisation vanishes at zero energy and/or zero {SOI}.
- Spin polarisation is sensitive to interface scattering, mixing left-going and right-going current. Also suppressed by non-zero onsite energies, non-zero orbital energy difference, reduced tunneling strength (connecting molecule to leads), and reduced curvature.
- *Intra-atomic {SOI} acts as effective Zeeman splitting-field*, causing transitions between states at equivalent phases/energetically degenerate in the same subsystem. (i.e. x$_{\textrm{↑/↓}}$ and z$_{\textrm{↓/↑}}$ states.) Unmixed states do not have perturbed current and can propagate through the molecule.
		- Effective fields rotate c.c.w. for both subsystems; inducing ↑-spin and ↓-spin currents in opposite directions. =={\textgreater} {TRS} preserved.
- Explicit expression derived for spin polarisation derived, dependent on chirality of helix and eigenenergies.},
	pages = {035445},
	number = {3},
	journaltitle = {Physical Review B},
	shortjournal = {Phys. Rev. B},
	author = {Utsumi, Yasuhiro and Entin-Wohlman, Ora and Aharony, Amnon},
	urldate = {2023-01-08},
	date = {2020-07-30},
	langid = {english},
	file = {Submitted Version:C\:\\Users\\19496\\Zotero\\storage\\KAB29V2L\\Utsumi et al. - 2020 - Spin selectivity through time-reversal symmetric h.pdf:application/pdf},
}

@article{fay_chirality-induced_2021,
	title = {Chirality-Induced Spin Coherence in Electron Transfer Reactions},
	volume = {12},
	issn = {1948-7185, 1948-7185},
	url = {https://pubs.acs.org/doi/10.1021/acs.jpclett.1c00009},
	doi = {10.1021/acs.jpclett.1c00009},
	abstract = {\#\#\# Summary:
The author considers how chirality induces chirality-induced spin coherence ({CISC}) in molecular electron transfer, using dynamical master equations to describe radical pair formation. (i.e. small molecule-molecule system at study; not leads-macromolecule.) 

- Charge-transfer reaction between charge-transfer radical-pair states

The author constructs a Hamiltonian describing a radical pair with two charge-transfer states (consisting of separable nuclear and spin terms), the dibatic coupling, and {SOC} between both states. A spin-density operator is defined for each charge-transfer state and solved using the Nakajima-Zwanzig equation.

Flipping the chirality of the molecule results in switching the sign of the {SOC} vector (due to it being axial). If the {SOC} vector is perpendicular to the z-axis, then the spin-states (initially already polarised) will be in coherence, yielding x-y magnetisation and a free-induction decay signal indicating spin polarisation. Achiral molecules will receive equal but opposite contributions from both signs of the {SOC} vector, resulting in loss of spin-polarisation.

- Charge transfer reaction between singlet precursor and radical-pair (single-electron transfer)

Using a similar Hamiltonian as the prior setup, the author sets the precursor to be singlet-only, while the radical-pair's singlet and triplet states are considered near-degenerate. Diabatic coupling and {SOC} terms are now  spin-conserving, so singlect projectors are inserted.

The Nakajima-Zwanzig equations are derived; Simplifying by assuming that radical-pair formation is rapid and irreversible (i.e. zero backreaction rate), the appropriate spin density-operators are found. Different chiralities switch the sign of the {SOC} vector, but so too are the initial coherence phases between singlet and triplet states. (Achiral systems receive equal contributions as above, so no change in initial coherence is generated.)

- Experimental detection of {CISC}: Out-of-phase Electron-spin Echo-envelope-modulation {EPR}.

Photon incidence on a precursor generates radical pairs, which are then exposed to two microwave pulses, generating a free-induction decay spin-echo-signal that is recorded over time, allowing probing of zero-quantum coherences (i.e. coherent mixing between singlet and triplet states in a spin-correlated radical pair) in the spin density-operator. An analytic expression is obtained for the {FID} signal, and it is shown that {CISC} occurs as above in weak and intermediate-coupling limits. 


\#\#\# Extra (Spin Polarisation):

Spin polarisation can arise from the charge-transfer reaction as the spin state evolves over time, when the phase change gains a real component. The spin polarisation will thus occur in flux together with spin-state evolution. Spin polarisation can then be relatively affixed by transferring the electron to a new state uncoupled to the charge-transfer reaction. The author (unpublished) estimates a maximal 50\% spin-polarisation from this interaction.


\#\#\# Comments:
- Picture of closed-system electron transfer is quite different from usual 'ballistic' scattering picture.
	- {TODO}: How to fit the two together?
- Coherences between spin states of the same charge-transfer state are long-lasting because the potential energy surfaces are identical.
	- Not the case for different charge-transfer states.
- The authors make the following approximations.
	- Nuclear vibration initially at local thermal equilibrium, so charge transfer coupling can be perturbed.
	- Population transfer is Markovian.
	- Rate constants are spin-interaction-independent.
		- Interface effects and non-equilibrium effects not accounted for.
- Analytic simulation of {EEMEPR} also does not account for spin relaxation, recombination, etc. Hyperfine interactions treated semi-classically.},
	pages = {1407--1412},
	number = {5},
	journaltitle = {The Journal of Physical Chemistry Letters},
	shortjournal = {J. Phys. Chem. Lett.},
	author = {Fay, Thomas P.},
	urldate = {2023-01-08},
	date = {2021-02-11},
	langid = {english},
	file = {Submitted Version:C\:\\Users\\19496\\Zotero\\storage\\ZBTNFG9I\\Fay - 2021 - Chirality-Induced Spin Coherence in Electron Trans.pdf:application/pdf},
}

