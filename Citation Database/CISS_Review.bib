
@article{macaluso_chiral-induced_2023,
	title = {Chiral-induced spin selectivity in photo-induced electron transfer: Investigating charge and spin dynamics in a master equation framework},
	volume = {159},
	issn = {0021-9606},
	url = {https://doi.org/10.1063/5.0160149},
	doi = {10.1063/5.0160149},
	shorttitle = {Chiral-induced spin selectivity in photo-induced electron transfer},
	abstract = {Investigating the role of chiral-induced spin selectivity in the generation of spin correlated radical pairs in a photoexcited donor–chiral bridge–acceptor system is fundamental to exploit it in quantum technologies. This requires a minimal master equation description of both charge separation and recombination through a chiral bridge. To achieve this without adding complexity and entering in the microscopic origin of the phenomenon, we investigate the implications of spin-polarizing reaction operators to the master equation. The explicit inclusion of coherent evolution yields non-trivial behaviors in the charge and spin dynamics of the system. Finally, we apply this master equation to a setup comprising a molecular qubit attached to the donor–bridge–acceptor molecule, enabling qubit initialization, control, and read-out. Promising results are found by simulating this sequence of operations assuming realistic parameters and achievable experimental conditions.},
	pages = {084301},
	number = {8},
	journaltitle = {The Journal of Chemical Physics},
	shortjournal = {The Journal of Chemical Physics},
	author = {Macaluso, Emilio and Chiesa, Alessandro and Santini, Paolo and Bittl, Robert and Carretta, Stefano},
	urldate = {2024-10-16},
	date = {2023-08-22},
	file = {Full Text PDF:C\:\\Users\\19496\\Zotero\\storage\\ZTN5UD8C\\Macaluso et al. - 2023 - Chiral-induced spin selectivity in photo-induced e.pdf:application/pdf;Snapshot:C\:\\Users\\19496\\Zotero\\storage\\XPKU3TAH\\Chiral-induced-spin-selectivity-in-photo-induced.html:text/html},
}

@article{das_insights_2024,
	title = {Insights into the Mechanism of Chiral-Induced Spin Selectivity: The Effect of Magnetic Field Direction and Temperature},
	volume = {36},
	rights = {© 2024 The Author(s). Advanced Materials published by Wiley-{VCH} {GmbH}},
	issn = {1521-4095},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/adma.202313708},
	doi = {10.1002/adma.202313708},
	shorttitle = {Insights into the Mechanism of Chiral-Induced Spin Selectivity},
	abstract = {Chiral oligopeptide monolayers are adsorbed on a ferromagnetic surface and their magnetoresistance is measured as a function of the angle between the magnetization of the ferromagnet and the surface normal. These measurements are conducted as a function of temperature for both enantiomers. The angle dependence is found to follow a changing trend with a period of 360°. Quantum simulations reveal that the angular distribution can be obtained only if the monolayer has significant effective spin orbit coupling ({SOC}), that includes contribution from the vibrations. The model shows that {SOC} only in the leads cannot reproduce the observed angular dependence. The simulation can reproduce the experiments if it included electron–phonon interactions and dissipation.},
	pages = {2313708},
	number = {29},
	journaltitle = {Advanced Materials},
	author = {Das, Tapan Kumar and Naaman, Ron and Fransson, Jonas},
	urldate = {2024-10-16},
	date = {2024},
	langid = {english},
	note = {\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1002/adma.202313708},
	keywords = {angle dependence, chirality, {CISS}, magnetoresistance, Spin},
	file = {Full Text PDF:C\:\\Users\\19496\\Zotero\\storage\\STNYNE9F\\Das et al. - 2024 - Insights into the Mechanism of Chiral-Induced Spin.pdf:application/pdf;Snapshot:C\:\\Users\\19496\\Zotero\\storage\\KFHPDWPT\\adma.html:text/html},
}

