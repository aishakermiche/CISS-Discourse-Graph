	url = {https://doi.org/10.1063/5.0146304},
	doi = {10.1063/5.0146304},
	abstract = {The diffusion propagator fully characterizes the diffusion process, which is highly sensitive to the confining boundaries and the structure within enclosed pores. While magnetic resonance has extensively been used to observe various features of the diffusion process, its full characterization has been elusive. Here, we address this challenge by employing a special sequence of magnetic field gradient pulses for measuring the diffusion propagator, which allows for “listening to the drum,” mapping structural dispersity, and determining not only the pore’s shape but also diffusive dynamics within it.},
	pages = {161102},
	number = {16},
	journaltitle = {The Journal of Chemical Physics},
	shortjournal = {The Journal of Chemical Physics},
	author = {Özarslan, Evren and Yolcu, Cem and Ordinola, Alfredo and Boito, Deneb and Dela Haije, Tom and Højgaard Jensen, Mathias and Herberthson, Magnus},
