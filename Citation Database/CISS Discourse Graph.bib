	file = {Submitted Version:C\:\\Users\\19496\\Zotero\\storage\\GL3R3KEQ\\Kulkarni et al. - 2020 - Highly Efficient and Tunable Filtering of Electrons' Spin by Supramolecular Chirality of Nanofiber‐B.pdf:application/pdf},
