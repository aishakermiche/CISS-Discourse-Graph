	author = {Eckshtain-Levi, Meital and Capua, Eyal and Refaely-Abramson, Sivan and Sarkar, Soumyajit and Gavrilov, Yulian and Mathew, Shinto P. and Paltiel, Yossi and Levy, Yaakov and Kronik, Leeor and Naaman, Ron},
	urldate = {2026-06-24},
