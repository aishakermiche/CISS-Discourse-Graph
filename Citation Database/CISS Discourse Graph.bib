	langid = {english},
	file = {Full Text PDF:C\:\\Users\\19496\\Zotero\\storage\\AZDQVI35\\Dunlop et al. - 2024 - Thermodynamically optimal protocols for dual-purpose qubit operations.pdf:application/pdf},
}

