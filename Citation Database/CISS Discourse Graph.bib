	langid = {english},
	file = {Full Text:C\:\\Users\\19496\\Zotero\\storage\\YYDVGX5E\\Chowdhury et al. - 2024 - Quantum Control of Radical-Pair Dynamics beyond Time-Local Optimization.pdf:application/pdf},
}

