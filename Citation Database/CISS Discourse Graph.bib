@article{xieBiocompatibleSurfaceFunctionalization2022,
	title = {Biocompatible surface functionalization architecture for a diamond quantum sensor},
	volume = {119},
	issn = {0027-8424, 1091-6490},
	url = {https://pnas.org/doi/full/10.1073/pnas.2114186119},
	doi = {10.1073/pnas.2114186119},
	abstract = {Significance
            Diamond-based quantum sensing enables nanoscale measurements of biological systems with unprecedented sensitivity. Potential applications of this emerging technology range from the investigation of fundamental biological processes to the development of next-generation medical diagnostics devices. One of the main challenges faced by bioquantum sensing is the need to interface quantum sensors with biological target systems. Specifically, such an interface needs to maintain the highly fragile quantum states of our sensor and at the same time be able to fish intact biomolecules out of solution and immobilize them on our quantum sensor surface. Our work overcomes these challenges by combining tools from quantum engineering, single-molecule biophysics, and material processing.
          , 
            Quantum metrology enables some of the most precise measurements. In the life sciences, diamond-based quantum sensing has led to a new class of biophysical sensors and diagnostic devices that are being investigated as a platform for cancer screening and ultrasensitive immunoassays. However, a broader application in the life sciences based on nanoscale {NMR} spectroscopy has been hampered by the need to interface highly sensitive quantum bit (qubit) sensors with their biological targets. Here, we demonstrate an approach that combines quantum engineering with single-molecule biophysics to immobilize individual proteins and {DNA} molecules on the surface of a bulk diamond crystal that hosts coherent nitrogen vacancy qubit sensors. Our thin (sub–5 nm) functionalization architecture provides precise control over the biomolecule adsorption density and results in near-surface qubit coherence approaching 100 μs. The developed architecture remains chemically stable under physiological conditions for over 5 d, making our technique compatible with most biophysical and biomedical applications.},
	pages = {e2114186119},
	number = {8},
	journaltitle = {Proceedings of the National Academy of Sciences},
	shortjournal = {Proc. Natl. Acad. Sci. U.S.A.},
	author = {Xie, Mouzhe and Yu, Xiaofei and Rodgers, Lila V. H. and Xu, Daohong and Chi-Durán, Ignacio and Toros, Adrien and Quack, Niels and De Leon, Nathalie P. and Maurer, Peter C.},
	urldate = {2026-06-24},
	date = {2022-02-22},
	langid = {english},
	file = {Submitted Version:C\:\\Users\\19496\\Zotero\\storage\\TIQQ495J\\Xie et al. - 2022 - Biocompatible surface functionalization architecture for a diamond quantum sensor.pdf:application/pdf},
}

@article{dasReviewQuantumBiosensors2024,
	title = {Review—Quantum Biosensors: Principles and Applications in Medical Diagnostics},
	volume = {3},
	issn = {2754-2726},
	url = {https://iopscience.iop.org/article/10.1149/2754-2726/ad47e2},
	doi = {10.1149/2754-2726/ad47e2},
	shorttitle = {Review—Quantum Biosensors},
	abstract = {Originating at the intersection of physics and biosensing, quantum biosensors ({QB}) are transforming medical diagnostics and personalized medicine by exploiting quantum phenomena to amplify sensitivity, specificity, and detection speed compared to traditional biosensors. Their foundation lies in the fusion of biological entities like {DNA}, proteins, or enzymes with quantum sensors, which elicits discernible alterations in light emissions when interacting with sample molecules. Their prowess in identifying disease-linked biomarkers presents an avenue for early diagnoses of conditions like Alzheimer’s and cancer. Beyond this, they enable real-time monitoring of treatment responses by capturing the dynamism of biomarkers, but {QB} still faces challenges, such as issues of stability, reproducibility, and intricate quantum interactions. Moreover, seamless integration into prevailing diagnostic frameworks necessitates careful consideration. Looking ahead, the evolution of {QB} navigates uncharted territories. Innovations in fabrication techniques, interdisciplinary collaborations, and standardization protocols emerge as pivotal areas of exploration. This comprehensive discourse encapsulates {QB}’s principles, diverse iterations, and burgeoning medical utilities. It delves into inherent challenges and limitations, shedding light on the potential trajectories of future research. As {QB} continues to evolve, its potential to redefine medical diagnostics becomes increasingly tangible. The saga of {QB} resonates with possibilities, poised to reshape the diagnostic landscape profoundly.
            
              
                
              
            
          , 
            Highlights
            
              
                
                  Highlighting various mechanisms and strategies to develop quantum biosensors, harmoniously united with biomolecules, triggers profound changes in light emissions, thereby fostering a new realm of diagnostic insights.
                
                
                  Expressing the myriad applications of quantum biosensors that we discuss encompass the early detection of disease-linked biomarkers and real-time monitoring of treatment responses.
                
                
                  Addressing the challenges intrinsic to the odyssey of quantum biosensors, encompassing stability, reproducibility, and intricate quantum interactions.
                
                
                  Summarizing our manuscript forges ahead to map potential future trajectories of Quantum biosensors, revolutionize medical diagnostics with unmatched sensitivity, real-time monitoring, and potential for personalized treatment, promising improved patient outcomes worldwide.},
	pages = {025001},
	number = {2},
	journaltitle = {{ECS} Sensors Plus},
	shortjournal = {{ECS} Sens. Plus},
	author = {Das, Suparna and Mazumdar, Hirak and Khondakar, Kamil Reza and Mishra, Yogendra Kumar and Kaushik, Ajeet},
	urldate = {2026-06-24},
	date = {2024-06-03},
	file = {Full Text:C\:\\Users\\19496\\Zotero\\storage\\RTPTZ2PT\\Das et al. - 2024 - Review—Quantum Biosensors Principles and Applications in Medical Diagnostics.pdf:application/pdf},
}

