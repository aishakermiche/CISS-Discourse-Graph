	langid = {english},
	file = {Submitted Version:C\:\\Users\\19496\\Zotero\\storage\\T7NH8JY5\\Chiesa et al. - 2023 - Chirality‐Induced Spin Selectivity An Enabling Technology for Quantum Applications.pdf:application/pdf},
}

