@article{salaSpinOrbitCoupling2026,
	title = {Spin–orbit coupling and beyond in chiral-induced spin selectivity},
	volume = {18},
	issn = {2040-3364, 2040-3372},
	url = {https://xlink.rsc.org/?DOI=D5NR04557F},
	doi = {10.1039/D5NR04557F},
	abstract = {Schematic illustration of the chiral-induced spin selectrivity effect. An unpolarized current acquires a finite spin polarisation by flowing through a chiral molecule whose geometrical chirality imbalances the two spins' transmission rates. Graphical abstract image refined using Microsoft Copilot.
          , 
            Chiral-Induced Spin Selectivity ({CISS}) describes the emergence of spin-polarized electron transport in chiral systems without magnetic fields—a remarkable effect in light-element materials with weak intrinsic spin–orbit coupling ({SOC}). This mini-review analyzes the microscopic origins of {CISS}, highlighting how molecular chirality, local electric fields, and dynamic distortions enhance effective {SOC} and drive spin-dependent transport. We critically assess existing models in terms of their symmetry constraints, phenomenological assumptions, and compliance with Onsager reciprocity. Recent developments combining relativistic quantum mechanics and complete multipole representations reveal a direct link between chirality density and spin current pseudoscalars, suggesting a field-theoretic foundation for {CISS}. These insights could help positioning light-element chiral nanomaterials as tunable platforms for probing and engineering spin-selective phenomena at the nanoscale.},
	pages = {9994--10011},
	number = {19},
	journaltitle = {Nanoscale},
	shortjournal = {Nanoscale},
	author = {Sala, Ruggero and Behera, Sushant Kumar and Roy Karmakar, Abhirup and Moioli, Matteo and Martinazzo, Rocco and Cococcioni, Matteo},
