	langid = {english},
	file = {Full Text:C\:\\Users\\19496\\Zotero\\storage\\KR8PZSBH\\Eckshtain-Levi et al. - 2016 - Cold denaturation induces inversion of dipole and spin transfer in chiral peptide monolayers.pdf:application/pdf},
}

